*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environments
movie_env/
venv/
env/
.venv/

# Data (too large for git — download via scripts)
data/*
!data/kg/
data/kg/*
!data/kg/kg_paths_for_recommendations.json
data.zip

# Results: ignore large regenerable files, keep key outputs
results/*

# Keep: documentation
!results/RESULTS.md
!results/RESULTS_ZH.md

# Keep: final experiment metrics (small JSON)
!results/ablation_results.json
!results/baseline_results.json
!results/feature_importance.json
!results/longtail_analysis.json

# Keep: Phase 2 RAG inputs
!results/recommendations.csv
!results/rag_eval_set.json

# Keep: recall model scores (for reproducibility)
!results/cf_scores.csv
!results/mf_scores.csv
!results/lightgcn_scores.csv
!results/multi_recall_scores.csv

# Keep: per-user metrics (for significance testing)
!results/per_user_ndcg.pkl
!results/ablation_per_user.pkl

# Keep: KG recall experiment results (JSON only, not large CSVs/PKLs)
!results/kg_recall_experiments/
results/kg_recall_experiments/**/*.csv
results/kg_recall_experiments/**/*.pkl

